---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="skills section" id="skills">
  <div class="container">
    <h2 class="section-title reveal">{t.skills.title}</h2>
    
    <div class="skills-categories">
      <!-- Frontend -->
      <div class="skill-category reveal">
        <h3 class="category-title">{t.skills.categories.frontend.title}</h3>
        <div class="skills-grid">
          {t.skills.categories.frontend.items.map((skill: string) => (
            <div class="skill-card glass">
              <span class="skill-name">{skill}</span>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Backend -->
      <div class="skill-category reveal">
        <h3 class="category-title">{t.skills.categories.backend.title}</h3>
        <div class="skills-grid">
          {t.skills.categories.backend.items.map((skill: string) => (
            <div class="skill-card glass">
              <span class="skill-name">{skill}</span>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Database -->
      <div class="skill-category reveal">
        <h3 class="category-title">{t.skills.categories.database.title}</h3>
        <div class="skills-grid">
          {t.skills.categories.database.items.map((skill: string) => (
            <div class="skill-card glass">
              <span class="skill-name">{skill}</span>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Tools -->
      <div class="skill-category reveal">
        <h3 class="category-title">{t.skills.categories.tools.title}</h3>
        <div class="skills-grid">
          {t.skills.categories.tools.items.map((skill: string) => (
            <div class="skill-card glass">
              <span class="skill-name">{skill}</span>
            </div>
          ))}
        </div>
      </div>
      
      <!-- AI -->
      <div class="skill-category reveal">
        <h3 class="category-title">{t.skills.categories.ai.title}</h3>
        <div class="skills-grid">
          {t.skills.categories.ai.items.map((skill: string) => (
            <div class="skill-card glass">
              <span class="skill-name">{skill}</span>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Principles -->
      <div class="skill-category reveal">
        <h3 class="category-title">{t.skills.categories.principles.title}</h3>
        <div class="skills-grid">
          {t.skills.categories.principles.items.map((skill: string) => (
            <div class="skill-card glass">
              <span class="skill-name">{skill}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Languages & Soft Skills -->
    <div class="additional-skills">
      <div class="skill-section reveal">
        <h3 class="section-subtitle">{t.skills.languages.title}</h3>
        <div class="languages-grid">
          {t.skills.languages.items.map((lang: any) => (
            <div class="language-card glass">
              <span class="language-name">{lang.language}</span>
              <span class="language-level">{lang.level}</span>
            </div>
          ))}
        </div>
      </div>
      
      <div class="skill-section reveal">
        <h3 class="section-subtitle">{t.skills.soft.title}</h3>
        <div class="soft-skills-list">
          {t.skills.soft.items.map((skill: string) => (
            <span class="soft-skill-tag">{skill}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills {
    background: var(--color-bg-secondary);
  }
  
  .skills-categories {
    display: grid;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }
  
  .skill-category {
    max-width: 1000px;
    margin: 0 auto;
    width: 100%;
  }
  
  .category-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
    position: relative;
    display: inline-block;
  }
  
  .category-title::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--gradient-primary);
    border-radius: var(--radius-lg);
  }
  
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-md);
  }
  
  .skill-card {
    padding: var(--space-md);
    border-radius: var(--radius-lg);
    text-align: center;
    transition: all var(--transition-base);
    cursor: default;
  }
  
  .skill-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-accent-primary);
  }
  
  .skill-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
  }
  
  .additional-skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .skill-section {
    background: var(--color-bg-primary);
    padding: var(--space-lg);
    border-radius: var(--radius-xl);
  }
  
  .section-subtitle {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }
  
  .languages-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  
  .language-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
  }
  
  .language-name {
    font-weight: 600;
    color: var(--color-text-primary);
  }
  
  .language-level {
    font-size: var(--text-sm);
    color: var(--color-accent-primary);
    font-weight: 500;
  }
  
  .soft-skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  
  .soft-skill-tag {
    padding: var(--space-xs) var(--space-md);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
    transition: all var(--transition-fast);
  }
  
  .soft-skill-tag:hover {
    border-color: var(--color-accent-primary);
    color: var(--color-accent-primary);
    transform: translateY(-2px);
  }
  
  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: var(--space-sm);
    }
    
    .additional-skills {
      grid-template-columns: 1fr;
    }
  }
</style>
